{
  "name": "wdio-puppeteer-video-service",
  "version": "0.7.1",
  "description": "WebdriverIO Service to record videos using Puppeteer",
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanLambe/wdio-puppeteer-video-service.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf build",
    "prepack": "npm run clean && npm run build && npm run test:unit",
    "test": "npm run test:unit && npm run test:e2e && npm run test:e2e:frameworks && npm run test:e2e:advanced",
    "test:e2e": "tsx tests/scripts/run-e2e-video-modes.ts multipart",
    "test:e2e:merge": "tsx tests/scripts/run-e2e-video-modes.ts merge",
    "test:e2e:both": "tsx tests/scripts/run-e2e-video-modes.ts both",
    "test:e2e:jasmine": "tsx tests/scripts/run-e2e-frameworks.ts jasmine",
    "test:e2e:cucumber": "tsx tests/scripts/run-e2e-frameworks.ts cucumber",
    "test:e2e:frameworks": "tsx tests/scripts/run-e2e-frameworks.ts both",
    "test:e2e:advanced": "tsx tests/scripts/run-e2e-advanced-options.ts all",
    "test:e2e:advanced:retry": "tsx tests/scripts/run-e2e-advanced-options.ts retry",
    "test:e2e:advanced:spec-file-retry": "tsx tests/scripts/run-e2e-advanced-options.ts spec-file-retry",
    "test:e2e:advanced:spec-level": "tsx tests/scripts/run-e2e-advanced-options.ts spec-level",
    "test:e2e:advanced:no-segment": "tsx tests/scripts/run-e2e-advanced-options.ts no-segment",
    "test:e2e:advanced:test-full-style": "tsx tests/scripts/run-e2e-advanced-options.ts test-full-style",
    "test:e2e:advanced:session-style": "tsx tests/scripts/run-e2e-advanced-options.ts session-style",
    "test:e2e:advanced:session-full-style": "tsx tests/scripts/run-e2e-advanced-options.ts session-full-style",
    "test:e2e:advanced:deferred-merge": "tsx tests/scripts/run-e2e-advanced-options.ts deferred-merge",
    "test:e2e:advanced:include-spec": "tsx tests/scripts/run-e2e-advanced-options.ts include-spec",
    "test:e2e:advanced:exclude-spec": "tsx tests/scripts/run-e2e-advanced-options.ts exclude-spec",
    "test:unit": "vitest run --dir tests/unit",
    "release:check": "npm run lint && npm run test:unit && npm run clean && npm run build && npm pack --dry-run",
    "release:notes": "tsx scripts/preview-release-notes.ts",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "keywords": [
    "webdriverio",
    "wdio",
    "wdio-service",
    "puppeteer",
    "video",
    "record"
  ],
  "author": {
    "name": "Dan Lambe",
    "email": "danjlambe@gmail.com"
  },
  "license": "Apache-2.0",
  "peerDependencies": {
    "@wdio/types": "^9.0.0",
    "puppeteer-core": "^24.0.0",
    "webdriverio": "^9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@cucumber/cucumber": "^12.7.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@wdio/cli": "^9.25.0",
    "@wdio/cucumber-framework": "^9.25.0",
    "@wdio/globals": "^9.23.0",
    "@wdio/jasmine-framework": "^9.25.0",
    "@wdio/local-runner": "^9.25.0",
    "@wdio/mocha-framework": "^9.25.0",
    "@wdio/spec-reporter": "^9.25.0",
    "@wdio/types": "^9.25.0",
    "expect-webdriverio": "^5.6.5",
    "ffmpeg-static": "^5.3.0",
    "fs-extra": "^11.3.4",
    "puppeteer-core": "^24.39.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "webdriverio": "^9.25.0"
  }
}
